# Copy to .env và chỉnh nếu cần (file .env đã được gitignore)
DATABASE_URL="postgresql://kun:kun@localhost:5432/kun?schema=public"

# Redis — bỏ trống để disable caching (fallback về DB queries)
REDIS_URL="redis://localhost:6379"

# JWT — chuỗi expiresIn (jsonwebtoken): 15m, 7d, 3600s, …
JWT_ACCESS_SECRET="change-me-access-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-min-32-chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# OTP — số phút / số lần / vòng bcrypt (10–15 khuyến nghị)
OTP_EXPIRES_MINUTES="2"
OTP_RATE_LIMIT_WINDOW_MINUTES="10"
OTP_RATE_LIMIT_MAX="3"
BCRYPT_SALT_ROUNDS="10"

# Google Sign-In — Client ID (Web) phải trùng với client tạo idToken trên frontend
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"

# CORS — origin của web (FE) + web-admin. Nhiều origin: cách nhau bởi dấu phẩy
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:5173,null"

# Admin JWT — tách secret access / refresh; refresh thường dài hơn (vd. 7d)
ADMIN_JWT_ACCESS_SECRET="change-me-admin-access-min-32-chars"
ADMIN_JWT_REFRESH_SECRET="change-me-admin-refresh-min-32-chars"
ADMIN_JWT_ACCESS_EXPIRES="1d"
ADMIN_JWT_REFRESH_EXPIRES="7d"

# POS — đơn tại quầy không chọn khách (tuỳ chọn; nếu không set, server tự tạo user email pos.walkin@kun.internal)
# POS_WALKIN_USER_ID="uuid-user-khach-le-neu-co-san"
# POS_WALKIN_EMAIL="pos.walkin@kun.internal"

# Đơn chuyển khoản — tự động huỷ nếu chưa thanh toán sau X phút (mặc định 15)
ORDER_BANK_TRANSFER_EXPIRY_MINUTES="15"

# TextBee SMS — bỏ trống để dùng chế độ mock (log console)
TEXTBEE_API_KEY=""
TEXTBEE_DEVICE_ID=""

# Cloudinary — upload avatar. Bỏ trống để dùng base64 fallback (dev)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_UPLOAD_PRESET=""
