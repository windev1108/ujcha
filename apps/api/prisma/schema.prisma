generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// `phone`, `email`, `googleId`, `referralCode`: `@unique` → PostgreSQL tạo index phục vụ lookup (đủ cho truy vấn theo SĐT/email).
model User {
  id           String  @id @default(uuid()) @db.Uuid
  phone        String? @unique
  email        String? @unique
  name         String
  avatar       String?
  googleId     String? @unique
  referralCode String  @unique
  /// Mã giới thiệu của người giới thiệu (quan hệ tới `User.referralCode`)
  referredBy   String?
  referrer     User?   @relation("Referrals", fields: [referredBy], references: [referralCode])
  referrals    User[]  @relation("Referrals")
  /// Phần thưởng giới thiệu nhận về (người được hưởng = referrer).
  referralRewardsBeneficiary ReferralReward[] @relation("ReferralRewardBeneficiary")
  /// Phần thưởng gắn với tài khoản được mời (người kích hoạt điều kiện).
  referralRewardsInvited     ReferralReward[] @relation("ReferralRewardInvited")
  milestoneClaims            ReferralMilestoneClaim[]
  sessions     Session[]
  addresses    Address[]
  cart         Cart?
  orders       Order[]
  groupOrdersHosted          GroupOrder[]               @relation("GroupOrderHost")
  groupOrderParticipations   GroupOrderParticipant[]    @relation("GroupOrderParticipant")
  pointBalance Float                @default(0)
  pointTransactions PointTransaction[]
  userVouchers      UserVoucher[]

  /// Hash bcrypt mật khẩu; null = chưa thiết lập (user cũ / đăng nhập Google).
  password        String?

  /// Đặt khi xác minh OTP SĐT thành công (điều kiện thưởng referral).
  phoneVerifiedAt DateTime?

  /// Bật/tắt nhận email khuyến mãi.
  emailMarketingEnabled Boolean   @default(false)
  /// Lần cuối upload avatar — giới hạn 1 lần / ngày.
  lastAvatarUploadAt    DateTime?

  registrationIp       String?
  registrationDeviceId String?
  suspiciousAt         DateTime?
  suspiciousReason     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([registrationIp])
  @@index([referredBy])
  @@index([registrationDeviceId])
}

enum PointTransactionType {
  earn
  spend
  expire
}

enum PointSource {
  order
  referral
  admin
  promotion
  voucher_redeem
}

/// Giao dịch điểm UjCha; earn có thể có expiresAt + remainingAmount (FIFO); spend/expire chỉ ghi nhận.
model PointTransaction {
  id          String               @id @default(uuid()) @db.Uuid
  userId      String               @db.Uuid
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        PointTransactionType
  /// Luôn > 0 (độ lớn giao dịch).
  amount      Float
  source      PointSource
  referenceId String?              @db.Uuid
  /// Chỉ type earn: thời điểm lô điểm hết hạn; null = không hết hạn.
  expiresAt   DateTime?
  /// Chỉ type earn: đến thời điểm này mới được spend (FIFO); null = dùng ngay.
  usableFrom  DateTime?
  /// Chỉ type earn: điểm còn lại trong lô (trừ dần khi spend FIFO).
  remainingAmount Float?
  createdAt   DateTime             @default(now())

  @@index([userId, createdAt])
  @@index([type, expiresAt])
}

/// Cấu hình điểm UjCha; chỉ một bản ghi `isActive = true` (đảm bảo trong service + unique partial index).
model PointConfig {
  id              String   @id @default(uuid()) @db.Uuid
  /// Ví dụ 100 → 1 điểm = 100đ.
  pointRate       Int
  earnPercent     Decimal  @db.Decimal(5, 2)
  maxUsagePercent Decimal  @db.Decimal(5, 2)
  minOrderAmount  Decimal  @db.Decimal(12, 2)
  delayHours      Int
  expireDays      Int
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
}

/// Chiến dịch tích điểm; khi đang trong khung giờ + bật → override `earnPercent` so với config.
model PointCampaign {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  earnPercent Decimal  @db.Decimal(5, 2)
  startAt     DateTime
  endAt       DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startAt, endAt])
  @@index([isActive])
}

/// OTP đăng nhập / xác minh SĐT; `code` lưu dạng hash.
model Otp {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  requestIp String?

  @@index([phone])
  @@index([phone, expiresAt])
  @@index([expiresAt])
  @@index([requestIp, createdAt])
}

/// Phiên đăng nhập; `refreshToken` lưu hash để validate rotation / revoke.
model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String
  deviceId     String
  ipAddress    String
  createdAt    DateTime @default(now())
  expiredAt    DateTime

  @@index([userId])
  @@index([deviceId])
  @@index([refreshToken])
  @@index([userId, expiredAt])
}

model Address {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullAddress String
  lat         Float
  lng         Float
  note        String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
  groupOrders GroupOrder[]

  @@index([userId])
  @@index([userId, isDefault])
}

/// Mỗi user tối đa một giỏ (userId unique).
model Cart {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @unique @db.Uuid
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id              String   @id @default(uuid()) @db.Uuid
  cartId          String   @db.Uuid
  cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId       String   @db.Uuid
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity        Int
  /// Lựa chọn người dùng đã chọn: { [groupName]: label }
  selectedOptions Json     @default("{}")
  /// Topping đã chọn (snapshot từ Product.toppings): [{ id, name, price }]
  toppingsJson    Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([cartId])
}

model Category {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  slug            String    @unique
  sortOrder       Int       @default(0)
  thumbnail       String?
  /// Bản dịch tên danh mục: { "en": "...", "ko": "..." }
  nameTranslation Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  products        Product[]

  @@index([sortOrder])
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  categoryId  String   @db.Uuid
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name        String
  slug        String   @unique
  /// Mã SKU hiển thị (vd: Ujcha-MTC-001), duy nhất khi có giá trị.
  sku         String?  @unique
  description String?
  price       Decimal  @db.Decimal(12, 2)
  /// Danh sách URL ảnh (CDN / link ngoài); ảnh đầu dùng làm đại diện.
  imageUrls   Json     @default("[]")
  /// Nhóm biến thể per-product: [{ id, name, selectionMin, selectionMax, values: [{label, priceDelta}] }]
  optionGroups    Json @default("[]")
  /// Topping per-product: [{ id, name, price, isActive }]
  toppings        Json @default("[]")
  /// Bản dịch tên món: { "en": "...", "ko": "...", "zh": "..." }
  nameTranslation Json @default("{}")
  /// Bản dịch mô tả món: { "en": "...", "ko": "...", "zh": "..." }
  descriptionTranslation Json @default("{}")
  isAvailable Boolean  @default(true)
  /// Đánh dấu hết hàng (hiển thị cho khách khi vẫn `isAvailable`).
  isSoldOut   Boolean  @default(false)
  /// Giảm giá theo sản phẩm (0–100%). Cộng với `ShopSettings.globalDiscountPercent`, tối đa 100%.
  discountPercent Int @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cartItems       CartItem[]
  orderItems      OrderItem[]
  groupOrderItems GroupOrderParticipantItem[]

  @@index([categoryId])
  @@index([isAvailable])
  @@index([isSoldOut])
}

/// Cấu hình chung cửa hàng (một dòng, id cố định `default`).
model ShopSettings {
  id                    String   @id
  /// Giảm giá áp dụng cho toàn bộ sản phẩm (0–100%), cộng với `Product.discountPercent`.
  globalDiscountPercent Int      @default(0)
  /// TTS voice ID (Viettel AI)
  ttsVoice              String   @default("hcm-diemmy")
  /// Tốc độ đọc (0.5 – 2.0)
  ttsSpeed              Float    @default(1.0)
  /// Định dạng trả về: 3 = Binary MP3
  ttsReturnOption       Int      @default(3)
  /// Bật/tắt bộ lọc từ ngữ Viettel
  ttsWithoutFilter      Boolean  @default(false)
  updatedAt             DateTime @updatedAt
}

/// Cấu hình thuế GTGT theo giai đoạn; chỉ một bản ghi `isActive = true` tại một thời điểm.
model VatConfig {
  id            String    @id @default(uuid()) @db.Uuid
  label         String
  vatPercent    Decimal   @db.Decimal(5, 2)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]

  @@index([isActive])
  @@index([effectiveFrom])
}

enum OrderType {
  delivery
  table
  pickup
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  delivering
  picked_up
  arrived
  completed
  cancelled
}

enum PaymentStatus {
  pending
  paid
}

enum PaymentType {
  cash
  bank_transfer
}

/// Bàn phục vụ qua QR.
model Table {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  /// Khu vực / tầng (nhóm trên UI admin).
  area      String   @default("Tầng 1")
  qrCode    String   @unique
  isActive  Boolean  @default(true)
  orders    Order[]
  groupOrders GroupOrder[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([area])
}

/// Shipper giao hàng (admin gán cho đơn delivery).
model Shipper {
  id        String   @id @default(uuid()) @db.Uuid
  /// Liên kết với tài khoản staff (tuỳ chọn, mỗi staff chỉ là 1 shipper).
  adminId   String?  @unique @db.Uuid
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  isActive  Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Order {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String?       @db.Uuid
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  type           OrderType
  addressId      String?       @db.Uuid
  address        Address?      @relation(fields: [addressId], references: [id], onDelete: SetNull)
  tableId        String?       @db.Uuid
  table          Table?        @relation(fields: [tableId], references: [id], onDelete: SetNull)
  pickupTime     DateTime?
  /// Giao hàng không đăng nhập: địa chỉ đầy đủ (khi không dùng addressId).
  guestDeliveryAddress String?
  guestDeliveryPhone   String?
  guestDeliveryName    String?

  totalAmount    Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)
  /// Giảm giá từ điểm UjCha (VND); chỉ trừ điểm khi thanh toán thành công.
  pointDiscountAmount Decimal  @default(0) @db.Decimal(12, 2)
  /// Điểm đã chọn cho đơn (chờ trừ khi paid).
  pointsReserved Int             @default(0)
  /// Điểm đã trừ sau khi thanh toán thành công.
  pointsConsumed Int             @default(0)

  finalAmount    Decimal       @db.Decimal(12, 2)
  shippingFee    Decimal       @default(0) @db.Decimal(12, 2)

  status         OrderStatus   @default(pending)
  paymentStatus  PaymentStatus @default(pending)
  paymentType    PaymentType   @default(cash)

  paymentCode    String        @unique
  /// Token duy nhất để khách quét QR bill tích điểm sau khi về nhà (single-use).
  loyaltyQrToken String        @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  shipperId      String?       @db.Uuid
  shipper        Shipper?      @relation(fields: [shipperId], references: [id], onDelete: SetNull)

  vatConfigId    String?       @db.Uuid
  vatConfig      VatConfig?    @relation(fields: [vatConfigId], references: [id], onDelete: SetNull)
  /// % VAT snapshot tại thời điểm tạo đơn (ví dụ 10.00).
  vatRate        Decimal       @default(0) @db.Decimal(5, 2)
  /// Tiền VAT (VND) = round(finalAmount × vatRate / 100).
  vatAmount      Decimal       @default(0) @db.Decimal(12, 2)

  items          OrderItem[]
  payments       Payment[]
  webhookLogs    PaymentWebhookLog[]
  referralRewards ReferralReward[]
  groupOrder     GroupOrder?

  paidAt         DateTime?

  /// Timestamps for each status transition (set when status changes)
  confirmedAt    DateTime?
  preparingAt    DateTime?
  readyAt        DateTime?
  deliveringAt   DateTime?
  pickedUpAt     DateTime?
  arrivedAt      DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId])
  @@index([userId, createdAt])
  @@index([status])
  @@index([paymentStatus])
  @@index([shipperId])
}

/// Giao dịch thanh toán (cổng / CK) — ghi nhận từ webhook hoặc đồng bộ sau.
model Payment {
  id              String   @id @default(uuid()) @db.Uuid
  transactionId   String   @unique
  amount          Decimal  @db.Decimal(12, 2)
  /// Nội dung chuyển khoản / mô tả giao dịch.
  content         String
  orderId         String   @db.Uuid
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
}

/// Log webhook thanh toán (debug / đối soát).
model PaymentWebhookLog {
  id           String   @id @default(uuid()) @db.Uuid
  provider     String?
  path         String?
  rawBody      String
  headersJson  Json?
  status       String?
  errorMessage String?
  orderId      String?  @db.Uuid
  order        Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([orderId])
}

model OrderItem {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @db.Uuid
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String   @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int
  /// Đơn giá snapshot tại thời điểm đặt.
  price     Decimal  @db.Decimal(12, 2)
  /// Snapshot topping: `[{ "toppingId", "name", "price" }]`
  extrasJson Json    @default("[]")
  /// Tuỳ chọn nhóm (size, đường, đá…): `{ "Size": "L", "Đường": "70%" }`
  optionsJson Json  @default("{}")
  /// Ghi chú món (ít đá, không bọc sẵn…)
  optionDetailsJson Json    @default("[]") // audit snapshot: [{ group, label, priceDelta }]
  note      String?

  @@index([orderId])
}

enum ReferralRewardStatus {
  pending
  credited
  void
}

/// Cấu hình chương trình giới thiệu (một bản ghi active).
model ReferralProgramConfig {
  id                        String   @id @default(uuid()) @db.Uuid
  isActive                  Boolean  @default(true)
  minOrderAmount            Decimal  @db.Decimal(12, 2)
  /// % của giá trị đơn đầu tiên → điểm thưởng cho người mời (thay thế điểm cố định).
  referrerCommissionPercent Float    @default(5)
  maxReferrerRewardsPerDay  Int      @default(20)
  blockSameIpAsReferrer     Boolean  @default(true)
  blockSameDeviceAsReferrer Boolean  @default(true)
  bronzeThreshold           Int      @default(5)
  bronzePoints              Int      @default(100)
  silverThreshold           Int      @default(10)
  silverPoints              Int      @default(250)
  goldThreshold             Int      @default(50)
  goldPoints                Int      @default(1000)
  diamondThreshold          Int      @default(100)
  diamondPoints             Int      @default(3000)
  /// Voucher tự động cấp cho mọi user mới khi đăng ký (chọn từ danh sách voucher).
  welcomeVoucherId          String?  @db.Uuid
  welcomeVoucher            Voucher? @relation(fields: [welcomeVoucherId], references: [id], onDelete: SetNull)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

/// Phần thưởng giới thiệu (ghi nhận khi đủ điều kiện business — tạo từ job/webhook sau).
model ReferralReward {
  id               String               @id @default(uuid()) @db.Uuid
  beneficiaryId  String               @db.Uuid
  beneficiary    User                 @relation("ReferralRewardBeneficiary", fields: [beneficiaryId], references: [id], onDelete: Cascade)
  referredUserId String               @db.Uuid
  referredUser   User                 @relation("ReferralRewardInvited", fields: [referredUserId], references: [id], onDelete: Cascade)
  amount         Decimal              @db.Decimal(12, 2)
  status         ReferralRewardStatus @default(pending)
  orderId        String?              @db.Uuid
  order          Order?               @relation(fields: [orderId], references: [id], onDelete: SetNull)
  note           String?
  /// Điểm đã cộng cho referrer (A).
  referrerPointsGranted Int?
  /// Voucher đã tạo cho người được mời (B).
  refereeVoucherId      String?              @db.Uuid
  refereeVoucher        Voucher?             @relation(fields: [refereeVoucherId], references: [id], onDelete: SetNull)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([beneficiaryId])
  @@index([referredUserId])
  @@index([status])
  @@index([createdAt])
}

/// Ghi nhận user đã claim mốc thưởng affiliate (mỗi tier chỉ claim một lần).
model ReferralMilestoneClaim {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier      String
  points    Int
  claimedAt DateTime @default(now())

  @@unique([userId, tier])
  @@index([userId])
  @@index([tier])
}

enum VoucherDiscountType {
  percent
  fixed_amount
}

enum UserVoucherSource {
  welcome
  referral
  admin_grant
  point_redeem
}

/// Mã giảm giá (quy tắc áp dụng khi checkout).
model Voucher {
  id                String               @id @default(uuid()) @db.Uuid
  code              String               @unique
  name              String
  discountType      VoucherDiscountType
  discountValue     Decimal              @db.Decimal(12, 2)
  minOrderAmount    Decimal              @default(0) @db.Decimal(12, 2)
  maxDiscountAmount Decimal?             @db.Decimal(12, 2)
  startsAt          DateTime?
  endsAt            DateTime?
  usageLimit        Int?
  perUserLimit      Int                  @default(1)
  isActive          Boolean              @default(true)
  /// Voucher chào mừng user mới — hệ thống tự cấp khi đăng ký.
  isWelcome         Boolean              @default(false)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([isActive])
  @@index([isWelcome])
  @@index([startsAt, endsAt])

  referralRewards      ReferralReward[]
  userVouchers         UserVoucher[]
  referralProgramConfigs ReferralProgramConfig[]
  pointRewardCatalogs  PointRewardCatalog[]
}

/// Danh mục phần thưởng đổi điểm: X điểm → cấp voucher Y cho user.
model PointRewardCatalog {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  /// Số điểm cần để đổi.
  pointCost   Int
  /// Voucher template cấp cho user khi đổi thành công.
  voucherId   String   @db.Uuid
  voucher     Voucher  @relation(fields: [voucherId], references: [id], onDelete: Restrict)
  imageUrl    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

/// Voucher được cấp riêng cho từng user — túi voucher cá nhân.
model UserVoucher {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @db.Uuid
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  voucherId   String            @db.Uuid
  voucher     Voucher           @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  source      UserVoucherSource @default(admin_grant)
  /// null = chưa sử dụng
  usedAt      DateTime?
  usedOrderId String?           @db.Uuid
  createdAt   DateTime          @default(now())

  @@unique([userId, voucherId])
  @@index([userId])
  @@index([voucherId])
  @@index([userId, usedAt])
}

enum AdminRole {
  super_admin
  staff
}

model Admin {
  id          String    @id @default(uuid()) @db.Uuid
  /// Số điện thoại — định danh đăng nhập chính.
  phone       String?   @unique
  /// Email tuỳ chọn (thông báo, phục hồi tài khoản).
  email       String?   @unique
  /// bcrypt hash của mật khẩu.
  password    String?
  name        String?
  role        AdminRole
  address     String?
  isActive    Boolean   @default(true)
  /// Danh sách quyền trang được cấp cho staff (bỏ qua với super_admin).
  permissions String[]  @default([])
  createdAt   DateTime  @default(now())
  posts       Post[]
  actionLogs  AdminActionLog[]
  attendance  StaffAttendance[]
  faceProfile StaffFaceProfile?
  shipper     Shipper?
}

/// Cấu hình ca làm việc (một dòng cố định id = "default").
model ShiftConfig {
  id               String   @id @default("default")
  /// Giờ vào ca: phút tính từ 00:00 VN (ví dụ 480 = 08:00).
  startMinutes     Int      @default(480)
  /// Giờ tan ca: phút tính từ 00:00 VN (ví dụ 1020 = 17:00).
  endMinutes       Int      @default(1020)
  /// Biên độ cho phép (phút) — trong khoảng này vẫn tính đúng giờ.
  toleranceMinutes Int      @default(0)
  updatedAt        DateTime @updatedAt
}

/// Cấu hình vị trí cửa hàng (một dòng cố định id = "default").
model StoreLocation {
  id           String   @id @default("default")
  lat          Float    @default(0)
  lng          Float    @default(0)
  /// Bán kính hợp lệ để chấm công (mét).
  radiusMeters Int      @default(100)
  /// Địa chỉ văn bản hiển thị cho khách (VD: "42 Nguyễn Huệ, Q1, TP.HCM").
  address      String   @default("")
  /// Số điện thoại liên hệ cửa hàng.
  phone        String?
  updatedAt    DateTime @updatedAt
}

/// Hồ sơ nhận diện khuôn mặt nhân viên — descriptor 128 chiều từ face-api.js.
model StaffFaceProfile {
  id             String   @id @default(uuid()) @db.Uuid
  adminId        String   @unique @db.Uuid
  admin          Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  /// Float32Array serialised → number[128].
  descriptorJson Json
  /// URL ảnh đại diện để admin xem.
  imageUrl       String?
  updatedAt      DateTime @updatedAt
}

enum AttendanceType {
  checkin
  checkout
}

/// Bản ghi chấm công (check-in / check-out).
model StaffAttendance {
  id             String         @id @default(uuid()) @db.Uuid
  adminId        String         @db.Uuid
  admin          Admin          @relation(fields: [adminId], references: [id], onDelete: Cascade)
  type           AttendanceType
  lat            Float?
  lng            Float?
  /// Khoảng cách so với cửa hàng (mét) tại thời điểm chấm.
  distanceMeters Float?
  /// Euclidean distance giữa face descriptor live và reference; < 0.6 = match.
  faceDistance   Float?
  createdAt      DateTime       @default(now())

  @@index([adminId, createdAt])
  @@index([createdAt])
}


/// Cấu hình thanh toán SePay QR — một dòng cố định id = "default".
model PaymentConfig {
  id            String   @id
  bankCode      String   @default("")
  accountNumber String   @default("")
  accountName   String   @default("")
  sePayApiKey   String   @default("")
  isEnabled     Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}

/// Nhật ký thao tác admin (điểm, v.v.).
model AdminActionLog {
  id           String   @id @default(uuid()) @db.Uuid
  adminId      String   @db.Uuid
  admin        Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action       String
  targetUserId String?  @db.Uuid
  payload      Json?
  createdAt    DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action])
}

enum PostType {
  news
  blog
  promotion
}

enum PostStatus {
  draft
  published
}

enum PostContentFormat {
  markdown
  html
}

model Post {
  id            String            @id @default(uuid()) @db.Uuid
  title         String
  slug          String            @unique
  content       String            @db.Text
  contentFormat PostContentFormat @default(markdown)
  thumbnail     String?
  type          PostType
  status        PostStatus        @default(draft)
  authorId      String            @db.Uuid
  author        Admin             @relation(fields: [authorId], references: [id], onDelete: Restrict)
  publishedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status])
  @@index([type])
  @@index([authorId])
  @@index([publishedAt])
}

/// Tổng hợp doanh thu từng ngày theo nền tảng (Grab, Shopee…)
model PlatformRevenueSummary {
  id              String   @id @default(uuid()) @db.Uuid
  platform        String   // 'grab' | 'shopee'
  date            String   // 'YYYY-MM-DD' (giờ VN)
  totalEarnings   Int      @default(0) // thu nhập shop (minor unit = VNĐ)
  revenue         Int      @default(0) // doanh thu gross
  completedOrders Int      @default(0)
  cancelledOrders Int      @default(0)
  rawJson         Json?
  syncedAt        DateTime @default(now())

  @@unique([platform, date])
  @@index([platform, date])
  @@map("platform_revenue_summaries")
}

/// Thông tin phiên bản mới nhất của UjCha POS — singleton (id = "singleton").
model PosRelease {
  id           String   @id @default("singleton")
  version      String   @default("1.0.0")
  downloadUrl  String   @default("")
  releaseNotes String   @default("") @db.Text
  updatedAt    DateTime @updatedAt
}

/// Phản hồi từ khách hàng — chỉ admin xem và xóa, không chỉnh sửa.
model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  name      String?
  email     String?
  phone     String?
  content   String   @db.Text
  rating    Int?
  ip        String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([ip, createdAt])
}

/// Cấu hình phí vận chuyển — singleton id = "default".
model ShippingConfig {
  id            String   @id @default("default")
  isActive      Boolean  @default(true)
  /// Phí cơ bản (VND) cho baseKm km đầu tiên.
  baseFee       Int      @default(15000)
  /// Số km miễn phí đầu tiên trong baseFee.
  baseKm        Float    @default(2)
  /// Phí mỗi km vượt quá baseKm (VND/km).
  feePerKm      Int      @default(5000)
  /// Khoảng cách tối đa hỗ trợ giao hàng (km).
  maxDistanceKm Float    @default(15)
  /// Giá trị đơn tối thiểu để miễn phí giao hàng (0 = không có). VND.
  freeThreshold Int      @default(200000)
  updatedAt     DateTime @updatedAt
}

/// Nhật ký SMS gửi qua TextBee — dùng để theo dõi và debug OTP.
model SmsLog {
  id         String   @id @default(uuid()) @db.Uuid
  phone      String
  message    String
  textbeeId  String?
  status     String   @default("pending")
  error      String?
  createdAt  DateTime @default(now())

  @@index([phone, createdAt])
  @@index([createdAt])
  @@index([status])
}

/// Thông báo trong ứng dụng cho người dùng.
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  type      String
  title     String
  content   String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
  @@index([userId, isRead])
}

// ─── Group Order ────────────────────────────────────────────────────────────

enum GroupOrderStatus {
  collecting
  locked
  completed
  cancelled
}

enum GroupPaymentMode {
  host_pays
  split
}

enum GroupParticipantPaymentStatus {
  pending
  paid
}

enum GroupParticipantPaymentType {
  cash
  bank_transfer
}

model GroupOrder {
  id          String           @id @default(uuid()) @db.Uuid
  token       String           @unique
  hostUserId  String           @db.Uuid
  host        User             @relation("GroupOrderHost", fields: [hostUserId], references: [id], onDelete: Cascade)
  status      GroupOrderStatus @default(collecting)
  paymentMode GroupPaymentMode
  type        OrderType
  addressId   String?          @db.Uuid
  address     Address?         @relation(fields: [addressId], references: [id], onDelete: SetNull)
  tableId     String?          @db.Uuid
  table       Table?           @relation(fields: [tableId], references: [id], onDelete: SetNull)
  pickupTime  DateTime?
  paymentType GroupParticipantPaymentType @default(cash)
  shippingFee Decimal          @default(0) @db.Decimal(12, 2)
  note        String?
  expiresAt   DateTime
  orderId     String?          @unique @db.Uuid
  order       Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  participants GroupOrderParticipant[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([token])
  @@index([hostUserId])
  @@index([status])
}

model GroupOrderParticipant {
  id             String                        @id @default(uuid()) @db.Uuid
  groupOrderId   String                        @db.Uuid
  groupOrder     GroupOrder                    @relation(fields: [groupOrderId], references: [id], onDelete: Cascade)
  userId         String?                       @db.Uuid
  user           User?                         @relation("GroupOrderParticipant", fields: [userId], references: [id], onDelete: SetNull)
  guestName      String?
  sessionToken   String                        @unique
  isHost         Boolean                       @default(false)
  isReady        Boolean                       @default(false)
  paymentStatus  GroupParticipantPaymentStatus @default(pending)
  paymentType    GroupParticipantPaymentType?
  paymentQrToken String?                       @unique
  paidAt         DateTime?
  joinedAt       DateTime                      @default(now())
  items          GroupOrderParticipantItem[]

  @@index([groupOrderId])
  @@index([userId])
  @@index([sessionToken])
}

model GroupOrderParticipantItem {
  id              String                @id @default(uuid()) @db.Uuid
  participantId   String                @db.Uuid
  participant     GroupOrderParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  productId       String                @db.Uuid
  product         Product               @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity        Int
  unitPrice       Decimal               @db.Decimal(12, 2)
  selectedOptions Json                  @default("{}")
  toppingsJson    Json                  @default("[]")
  note            String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([participantId])
}

/// Cấu hình đơn nhóm & bậc giảm giá nhóm — singleton id = "default".
model GroupOrderConfig {
  id String @id @default("default")
  isEnabled         Boolean  @default(true)
  expiryMinutes     Int      @default(120)
  /// JSON mảng bậc giảm giá: [{ minParticipants: 2, discountPercent: 5 }, ...]
  discountTiersJson Json     @default("[]")
  updatedAt         DateTime @updatedAt
}
