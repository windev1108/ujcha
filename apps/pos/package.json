{
  "name": "ujcha-pos",
  "version": "1.0.3",
  "description": "UjCha POS — Hệ thống bán hàng tại quầy",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "gen-icon": "node scripts/gen-icon.js",
    "predist": "node scripts/gen-icon.js",
    "dist": "electron-vite build && electron-builder --win --x64",
    "dist:dir": "electron-vite build && electron-builder --win --x64 --dir",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^32.2.7",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@number-flow/react": "^0.6.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.7.9",
    "dayjs": "^1.11.20",
    "iconv-lite": "^0.7.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.469.0",
    "motion": "^12.38.0",
    "mqtt": "^5.15.1",
    "node-thermal-printer": "^4.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "socket.io-client": "^4.8.1",
    "three": "^0.184.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.3"
  }
