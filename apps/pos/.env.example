VITE_API_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# URL của web user app — dùng để build loyalty QR trên bill POS
VITE_WEB_URL=https://your-web-domain.com

# Analy MQTT broker (wss required — plain ws does not work)
VITE_ANALY_MQTT_URL=wss://147.136.146.132:8084/mqtt

# ShopeeFood restaurant ID(s) for MQTT subscription
# Run POS once without this set — check logs for "DEBUG new order detected — restaurantId=XXXXX"
# Then set this to that ID to only receive orders for your restaurant
VITE_SPF_RESTAURANT_IDS=

# Internal API key for Analy ingest endpoint (optional, protects /admin/external/analy)
VITE_INTERNAL_ANALY_KEY=
